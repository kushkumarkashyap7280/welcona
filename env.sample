

NODE_ENV="development"

ADMIN_NOTIFICATION_EMAIL="your_admin_notification_email"


#  openssl rand -base64 32

JWT_SECRET="your_jwt_secret"

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://your_supabase_pooler_url"

# Direct connection to the database. Used for migrations
DIRECT_URL="your_supabase_direct_url"

# file uploading supabase credentials

NEXT_PUBLIC_SUPABASE_URL="your_supabase_url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="your_supabase_storage_bucket"


# resendgrid api key
RESEND_API_KEY="your_resendgrid_api_key"
RESEND_FROM_EMAIL=" your_domain_name <your_domain_email>"


RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

NEXT_PUBLIC_APP_URL="your_app_url"

# Bulk order threshold in paise (₹10,000 = 1000000 paise)
BULK_ORDER_THRESHOLD=your_bulk_order_threshold

# Bulk order threshold in rupees (for frontend display)
NEXT_PUBLIC_BULK_THRESHOLD=your_bulk_threshold

# WhatsApp CRM number (with country code, no +)
WHATSAPP_NUMBER=your_whatsapp_number

# Bulk order WhatsApp message template ({orderId} gets replaced)
WHATSAPP_BULK_MESSAGE="Hi, I have placed a bulk order on your_domain_name. My Order ID is {orderId}. Please help me complete the payment."
